<?xml version="1.0" encoding="utf-8"?>
<!--
    Defang accessibility service configuration.

    We listen for two event types:
    - typeWindowStateChanged: detects app switches and browser page navigations
    - typeWindowContentChanged: detects URL bar text changes within a browser
      (needed for in-page navigation in SPAs / link clicks that don't fire STATE_CHANGED)

    canRetrieveWindowContent="true" is required to read the URL bar node from the browser
    window tree. We only read URL bar nodes — we do not read page content.

    packageNames is intentionally omitted — omitting it means ALL packages.
    Setting it to an empty string "" incorrectly filters to zero packages.
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged|typeWindowContentChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:canRetrieveWindowContent="true"
    android:description="@string/accessibility_service_description"
    android:notificationTimeout="100" />
